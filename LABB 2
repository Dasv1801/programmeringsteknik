# Uppgift 1a:
def int_to_hexa_char(tal):
    hexa_chars = "0123456789ABCDEF"
    return hexa_chars[tal]
    
# Uppgift 1b:
def hexa_char_to_int(symbol):
    hexa_chars = "0123456789ABCDEF"
    return hexa_chars.find(symbol)

# kod som provtestar att "def" ovanför fungerar.
print(int_to_hexa_char(13))
print(int_to_hexa_char(4))

print(hexa_char_to_int("5"))
print(hexa_char_to_int("D"))
